[Unit]
Description=nightshift — unattended overnight code-review-and-fix steward
Documentation=https://github.com/sebastianlang84/nightshift
# No After/Wants=network-online.target here: this is a systemd *user* unit (installed by
# bin/schedule.sh via `systemctl --user`; see docs/deployment.md). network-online.target is
# only ever activated in the *system* manager, by its implementer services
# (NetworkManager-wait-online.service / systemd-networkd-wait-online.service). The per-user
# manager has no such implementer, so ordering on it here is a silent no-op that would
# falsely imply the run waits for connectivity. The launcher shells out to network-dependent
# CLIs (claude/gh); their own retries/failures surface a missing network, and linger keeps
# the timer honest across logout — but systemd cannot network-gate a user unit.

[Service]
Type=oneshot
# __NIGHTSHIFT_HOME__ is substituted by bin/schedule.sh at install time.
ExecStart=__NIGHTSHIFT_HOME__/bin/nightshift-cron.sh
# Unattended agent runs can be long; the open-branch cap bounds throughput, but a
# hard wall-clock ceiling guards against a hang (roughly the subscription window).
TimeoutStartSec=5h
# Be a polite neighbour on a workstation.
Nice=10
IOSchedulingClass=idle
